#!/usr/bin/env bash
set -euo pipefail

# Resolve the package root (one level up from bin/)
PKG_DIR="$(cd "$(dirname "$0")/.." && pwd)"

usage() {
  echo "Usage: codeforge-dashboard [options]"
  echo ""
  echo "Options:"
  echo "  --port <port>    Port to listen on (default: 5173)"
  echo "  --host <host>    Host to bind to (default: 127.0.0.1)"
  echo "  --version        Show version"
  echo "  --help           Show this help message"
}

PORT=5173
HOST=127.0.0.1

while [[ $# -gt 0 ]]; do
  case "$1" in
    --port)
      [[ $# -lt 2 ]] && { echo "Error: --port requires a value" >&2; exit 1; }
      PORT="$2"
      shift 2
      ;;
    --host)
      [[ $# -lt 2 ]] && { echo "Error: --host requires a value" >&2; exit 1; }
      HOST="$2"
      shift 2
      ;;
    --version)
      VERSION=$(cd "$PKG_DIR" && bun -e "console.log(require('./package.json').version)")
      echo "codeforge-dashboard v${VERSION}"
      exit 0
      ;;
    --help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

export PORT="$PORT"
export HOST="$HOST"

exec bun run "$PKG_DIR/src/server/index.ts"
