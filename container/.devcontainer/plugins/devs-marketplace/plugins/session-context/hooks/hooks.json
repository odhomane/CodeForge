{
	"description": "Context injection at session boundaries: git state, TODO harvesting, edit tracking, commit reminders",
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/collect-session-edits.py",
						"timeout": 3
					}
				]
			}
		],
		"SessionStart": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/git-state-injector.py",
						"timeout": 10
					},
					{
						"type": "command",
						"command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/todo-harvester.py",
						"timeout": 8
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/commit-reminder.py",
						"timeout": 8
					}
				]
			}
		]
	}
}
